{
  "name": "metabolism-study-app",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "validate:content": "node scripts/validate-content.mjs",
    "build": "npm run validate:content && tsc --noEmit && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run test && npm run build"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.53.0",
