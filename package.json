    "ts-fsrs": "^5.2.0",
    "zod": "^4.0.10"
  },
  "devDependencies": {
    "@types/node": "^24.0.15",
    "fake-indexeddb": "^6.0.1",
    "sharp": "^0.35.3",
    "typescript": "^5.8.3",
    "vite": "^7.0.6",
    "vite-plugin-pwa": "^1.0.2",
    "vitest": "^3.2.4"
  }
}
